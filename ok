-- 7. PROXIMITY PROMPTS in workspace (E-key interactions)
-- ══════════════════════════════════════════════════════════════
sec("7. All ProximityPrompts in workspace")
pcall(function()
    local count = 0
    for _, pp in ipairs(WS:GetDescendants()) do
        if pp:IsA("ProximityPrompt") then
            count = count + 1
            p("  " .. pp:GetFullName())
            p("    ActionText=" .. pp.ActionText
              .. "  ObjectText=" .. pp.ObjectText
              .. "  Enabled=" .. tostring(pp.Enabled))
            -- parent name for context
            if pp.Parent then
                p("    Parent: " .. pp.Parent.Name .. "  [" .. pp.Parent.ClassName .. "]")
                -- grandparent
                if pp.Parent.Parent then
                    p("    GrandParent: " .. pp.Parent.Parent.Name)
                end
            end
        end
    end
    if count == 0 then p("  (none found — may use ClickDetector or custom system)") end
end)

-- ══════════════════════════════════════════════════════════════
-- 8. CLICK DETECTORS in workspace
-- ══════════════════════════════════════════════════════════════
sec("8. ClickDetectors in workspace")
pcall(function()
    local count = 0
    for _, cd in ipairs(WS:GetDescendants()) do
        if cd:IsA("ClickDetector") then
            count = count + 1
            p("  " .. cd:GetFullName())
            if cd.Parent then
                p("    Parent: " .. cd.Parent.Name .. "  [" .. cd.Parent.ClassName .. "]")
            end
        end
    end
    if count == 0 then p("  (none found)") end
end)

-- ══════════════════════════════════════════════════════════════
-- 9. WORKSPACE MODEL/PART NAMES matching object keywords
-- ══════════════════════════════════════════════════════════════
sec("9. Workspace descendants matching bed/bath/tv/fridge/food keywords")
local objKW = {"bed","bath","tub","shower","tv","television","fridge","refrigerator",
               "food","stove","oven","couch","sofa","toilet","sink"}
pcall(function()
    local found = 0
    for _, desc in ipairs(WS:GetDescendants()) do
        local lname = desc.Name:lower()
        for _, kw in ipairs(objKW) do
            if lname:find(kw, 1, true) then
                found = found + 1
                p("  " .. desc:GetFullName() .. "  [" .. desc.ClassName .. "]")
                -- attributes
                local ok, attrs = pcall(function() return desc:GetAttributes() end)
                if ok then
                    for k, v in pairs(attrs) do p("    @" .. k .. " = " .. tostring(v)) end
                end
                -- check for ProximityPrompt/ClickDetector children
                local ok2, children = pcall(function() return desc:GetChildren() end)
                if ok2 then
                    for _, child in ipairs(children) do
                        if child:IsA("ProximityPrompt") or child:IsA("ClickDetector") then
                            p("    HAS: " .. child.ClassName
                              .. (child:IsA("ProximityPrompt") and
                                  "  action=" .. child.ActionText .. "  obj=" .. child.ObjectText
                                  or ""))
                        end
                    end
                end
                break
            end
        end
    end
    if found == 0 then p("  (nothing found by name — objects may have generic names)") end
end)

-- ══════════════════════════════════════════════════════════════
-- 10. ALL CONTROLLERS via ControllerManager if present
-- ══════════════════════════════════════════════════════════════
sec("10. ControllerManager — all controllers")
pcall(function()
    local CM = tryRequire("Core.Controller.ControllerManager")
             or tryRequire("ControllerManager")
    if not CM then p("  ControllerManager not found at common paths"); return end

    -- Try to get all controller names
    local allCtrl = nil
    for _, key in ipairs({"getAllControllers","controllers","_controllers","_map","_registry"}) do
        if CM[key] then
            local ok, val = pcall(function()
                return type(CM[key])=="function" and CM[key]() or CM[key]
            end)
            if ok and type(val) == "table" then
                allCtrl = val; break
            end
        end
    end

    if allCtrl then
        for name in pairs(allCtrl) do p("  ctrl: " .. tostring(name)) end
    else
        p("  Could not list controllers — dump CM functions:")
        local fns = {}
        for k, v in pairs(CM) do
            if type(v) == "function" then table.insert(fns, k) end
        end
        table.sort(fns)
        for _, f in ipairs(fns) do p("    fn: " .. f) end
    end
end)

-- ══════════════════════════════════════════════════════════════
