-- 5. REQUIRE LIKELY MODULES — dump functions + values
-- ══════════════════════════════════════════════════════════════
sec("5. Require mood/stats/data modules — function names + values")
local function dumpModule(name, mod)
    if type(mod) ~= "table" then
        p("  " .. name .. " = " .. type(mod) .. ": " .. tostring(mod))
        return
    end
    local fns, vals = {}, {}
    for k, v in pairs(mod) do
        if type(v) == "function" then table.insert(fns, tostring(k))
        else table.insert(vals, tostring(k) .. " = " .. tostring(v)) end
    end
    table.sort(fns); table.sort(vals)
    if #fns > 0 then
        p("  " .. name .. " FUNCTIONS:")
        for _, f in ipairs(fns) do p("    fn: " .. f) end
    end
    if #vals > 0 then
        p("  " .. name .. " VALUES:")
        for _, v in ipairs(vals) do p("    " .. v) end
    end
end

-- Scan RS for any module whose name contains a keyword, require it
local modKW = {"mood","stat","need","data","profile","player","client","house",
               "plot","interact","boost","bar","energy","hunger","hygiene","fun"}
pcall(function()
    for _, desc in ipairs(RS:GetDescendants()) do
        if desc:IsA("ModuleScript") then
            local lname = desc.Name:lower()
            for _, kw in ipairs(modKW) do
                if lname:find(kw, 1, true) then
                    p("\n  --> Requiring: " .. desc:GetFullName())
                    local ok, mod = pcall(require, desc)
                    if ok then
                        dumpModule(desc.Name, mod)
                    else
                        p("    FAILED: " .. tostring(mod))
                    end
                    break
                end
            end
        end
    end
end)

-- ══════════════════════════════════════════════════════════════
-- 6. WORKSPACE — FIND PLAYER PLOT
-- ══════════════════════════════════════════════════════════════
sec("6. Workspace — find player plot by every known pattern")
local userId   = LP.UserId
local userName = LP.Name

pcall(function()
    -- Pattern A: folder/model named after player
    local byName = WS:FindFirstChild(userName) or WS:FindFirstChild(userName .. "'s Plot")
    if byName then
        p("  FOUND by name: " .. byName:GetFullName() .. "  [" .. byName.ClassName .. "]")
    end

    -- Pattern B: any Model with Owner/OwnerName/PlayerId attribute
    local ownerAttrs = {"Owner","OwnerName","OwnerId","PlayerId","PlayerName","Username"}
    for _, model in ipairs(WS:GetDescendants()) do
        if model:IsA("Model") or model:IsA("Folder") then
            for _, attr in ipairs(ownerAttrs) do
                local val = model:GetAttribute(attr)
                if val then
                    local sval = tostring(val)
                    if sval == userName or sval == tostring(userId) then
                        p("  FOUND by attr [" .. attr .. "=" .. sval .. "]: "
                          .. model:GetFullName())
                    end
                end
            end
        end
    end

    -- Pattern C: folders named Plots/Houses/Homes/Apartments
    local containerNames = {"Plots","Houses","Homes","Apartments","Properties",
                            "Clients","Units","Rooms","Lots"}
    for _, cname in ipairs(containerNames) do
        local container = WS:FindFirstChild(cname, true)
        if container then
            p("  Container found: " .. container:GetFullName())
            for _, child in ipairs(container:GetChildren()) do
                p("    " .. child.Name .. "  [" .. child.ClassName .. "]")
                -- Check if it's the player's plot
                for _, attr in ipairs(ownerAttrs) do
                    local v = child:GetAttribute(attr)
                    if v then p("      @" .. attr .. " = " .. tostring(v)) end
                end
            end
        end
    end
end)

