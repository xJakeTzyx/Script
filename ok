-- ══════════════════════════════════════════════════════════════
sec("3. PlayerGui TextLabels matching mood keywords")
local moodKW = {"mood","fun","energy","hunger","hygiene","happy","tired","sleep",
                "bath","food","clean","stat","need","boost","bar","percent","level"}
pcall(function()
    for _, desc in ipairs(LP.PlayerGui:GetDescendants()) do
        if desc:IsA("TextLabel") then
            local lt = desc.Text:lower()
            local lname = desc.Name:lower()
            local hit = false
            for _, kw in ipairs(moodKW) do
                if lt:find(kw,1,true) or lname:find(kw,1,true) then hit=true; break end
            end
            if hit then
                p("  PATH: " .. desc:GetFullName())
                p("    text=" .. desc.Text .. "  visible=" .. tostring(desc.Visible))
            end
        end
        -- Also check Frame/ImageLabel names
        if desc:IsA("Frame") or desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
            local lname = desc.Name:lower()
            for _, kw in ipairs(moodKW) do
                if lname:find(kw,1,true) then
                    p("  UI: " .. desc:GetFullName() .. "  [" .. desc.ClassName .. "]"
                      .. "  visible=" .. tostring(desc.Visible))
                    -- Dump attributes
                    for k, v in pairs(desc:GetAttributes()) do
                        p("    @" .. k .. " = " .. tostring(v))
                    end
                    break
                end
            end
        end
    end
end)

