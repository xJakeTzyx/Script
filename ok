--[[
    DEEP DEBUG — AUTO MOOD & PLOT FINDER
    Covers every realistic location mood/plot data could live.
    Run from free roam (not in any interaction).
    Copies full output to clipboard.
    
    SECTIONS:
      1.  LocalPlayer attributes + value children
      2.  Character attributes
      3.  PlayerGui — scan ALL TextLabels for mood keywords
      4.  ReplicatedStorage — full module/remote tree dump
      5.  Require likely mood/stats/data modules
      6.  Workspace — find player plot by every known pattern
      7.  ProximityPrompts in workspace (E-key interactions)
      8.  ClickDetectors in workspace
      9.  All RemoteEvents / RemoteFunctions (full list)
      10. Bindable events/functions (local interaction signals)
      11. All controllers via ControllerManager if present
      12. Any "DataStore" or "Profile" cached on client
]]

local RS  = game:GetService("ReplicatedStorage")
local LP  = game:GetService("Players").LocalPlayer
local WS  = workspace

local lines = {}
local function p(...)
    local t = {}
    for i = 1, select("#", ...) do t[i] = tostring(select(i, ...)) end
    local s = table.concat(t, "  ")
    table.insert(lines, s)
    print(s)
end
local function sec(label)
    p("")
    p(string.rep("=", 56))
    p("  " .. label)
    p(string.rep("=", 56))
end
local function tryRequire(path)
    local parts = string.split(path, ".")
    local ok, result = pcall(function()
        local m = RS
        for _, part in ipairs(parts) do m = m[part] end
        return require(m)
    end)
    return ok and result or nil
end
-- Recursive RS scanner — stops at depth, reports names + class
local function scanFolder(obj, depth, maxDepth, filter)
    if depth > maxDepth then return end
    local ok, children = pcall(function() return obj:GetChildren() end)
    if not ok then return end
    for _, child in ipairs(children) do
        local lname = child.Name:lower()
        local match = true
        if filter then
            match = false
            for _, kw in ipairs(filter) do
                if lname:find(kw, 1, true) then match = true; break end
            end
        end
        if match then
            p(string.rep("  ", depth) .. child.Name .. "  [" .. child.ClassName .. "]")
        end
        if child:IsA("Folder") or child:IsA("Model")
        or child:IsA("ModuleScript") or child.ClassName == "Script" then
            -- recurse into containers regardless of match
            scanFolder(child, depth + 1, maxDepth, filter)
        end
    end
end

